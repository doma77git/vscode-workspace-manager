{
    "folders": [
        { "path": "..", "name": "${PROJECT_NAME}" }
    ],
    "settings": {
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "editor.rulers": [120],
        "files.encoding": "utf8",
        "files.exclude": {
            "**/.git": true,
            "**/vendor": true,
            "**/.bundle": true,
            "**/tmp": true
        },
        "search.exclude": {
            "**/vendor": true,
            "**/tmp": true
        },
        "[ruby]": {
            "editor.defaultFormatter": "Shopify.ruby-lsp",
            "editor.tabSize": 2
        },
        "rubyLsp.enabled": true,
        "terminal.integrated.defaultProfile.windows": "PowerShell 7 (full)",
        "terminal.integrated.shellIntegration.enabled": true
    },
    "extensions": {
        "recommendations": [
            "Shopify.ruby-lsp",
            "castwide.solargraph",
            "eamodio.gitlens",
            "editorconfig.editorconfig",
            "streetsidesoftware.code-spell-checker"
        ]
    },
    "tasks": {
        "version": "2.0.0",
        "tasks": [
            {
                "label": "Run",
                "detail": "ruby main.rb",
                "type": "shell",
                "command": "ruby",
                "args": ["${workspaceFolder}/main.rb"],
                "group": "none",
                "presentation": { "reveal": "always", "panel": "new" }
            },
            {
                "label": "Test",
                "detail": "bundle exec rspec",
                "type": "shell",
                "command": "bundle",
                "args": ["exec", "rspec"],
                "group": "test",
                "presentation": { "reveal": "always", "panel": "new" },
                "problemMatcher": []
            },
            {
                "label": "Install Dependencies",
                "detail": "bundle install",
                "type": "shell",
                "command": "bundle",
                "args": ["install"],
                "group": "none",
                "presentation": { "reveal": "always", "panel": "new" }
            },
            {
                "label": "Lint",
                "detail": "rubocop",
                "type": "shell",
                "command": "bundle",
                "args": ["exec", "rubocop"],
                "group": "test",
                "presentation": { "reveal": "always", "panel": "new" },
                "problemMatcher": []
            }
        ]
    },
    "git.remote": "${GIT_REMOTE}"
}
