{
    "folders": [{ "path": "..", "name": "${PROJECT_NAME}" }],
    "settings": {
        "editor.formatOnSave": true,
        "editor.tabSize": 4,
        "editor.rulers": [120],
        "files.exclude": { "**/.git": true, "**/bin": true, "**/obj": true },
        "search.exclude": { "**/bin": true, "**/obj": true },
        "omnisharp.enableRoslynAnalyzers": true,
        "omnisharp.organizeImportsOnFormat": true,
        "terminal.integrated.defaultProfile.windows": "PowerShell 7 (full)",
        "terminal.integrated.shellIntegration.enabled": true
    },
    "extensions": {
        "recommendations": [
            "ms-dotnettools.csdevkit",
            "ms-dotnettools.csharp",
            "ms-dotnettools.vscode-dotnet-runtime",
            "eamodio.gitlens",
            "editorconfig.editorconfig"
        ]
    },
    "tasks": {
        "version": "2.0.0",
        "tasks": [
            {
                "label": "Build",
                "type": "shell", "command": "dotnet", "args": ["build"],
                "group": "build",
                "presentation": { "reveal": "always", "panel": "new" },
                "problemMatcher": ["$msCompile"]
            },
            {
                "label": "Test",
                "type": "shell", "command": "dotnet", "args": ["test"],
                "group": "test",
                "presentation": { "reveal": "always", "panel": "new" }
            },
            {
                "label": "Run",
                "type": "shell", "command": "dotnet", "args": ["run"],
                "group": "none",
                "presentation": { "reveal": "always", "panel": "new" }
            }
        ]
    },
    "git.remote": "${GIT_REMOTE}"
}
