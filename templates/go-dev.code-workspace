{
    "folders": [
        { "path": "..", "name": "${PROJECT_NAME}" }
    ],
    "settings": {
        "editor.formatOnSave": true,
        "editor.tabSize": 4,
        "editor.rulers": [120],
        "files.encoding": "utf8",
        "files.exclude": {
            "**/.git": true
        },
        "search.exclude": {
            "**/vendor": true
        },
        "go.useLanguageServer": true,
        "go.formatTool": "goimports",
        "go.lintTool": "golangci-lint",
        "go.lintOnSave": "package",
        "go.testFlags": ["-v", "-count=1"],
        "go.coverOnSave": true,
        "go.coverOnSingleTest": true,
        "terminal.integrated.defaultProfile.windows": "PowerShell 7 (full)",
        "terminal.integrated.shellIntegration.enabled": true
    },
    "extensions": {
        "recommendations": [
            "golang.go",
            "eamodio.gitlens",
            "editorconfig.editorconfig",
            "streetsidesoftware.code-spell-checker"
        ]
    },
    "tasks": {
        "version": "2.0.0",
        "tasks": [
            {
                "label": "Run",
                "detail": "go run",
                "type": "shell",
                "command": "go",
                "args": ["run", "."],
                "group": "none",
                "presentation": { "reveal": "always", "panel": "new" },
                "problemMatcher": ["$go"]
            },
            {
                "label": "Test",
                "detail": "go test -v -cover ./...",
                "type": "shell",
                "command": "go",
                "args": ["test", "-v", "-cover", "./..."],
                "group": "test",
                "presentation": { "reveal": "always", "panel": "new" },
                "problemMatcher": ["$go"]
            },
            {
                "label": "Lint",
                "detail": "golangci-lint run",
                "type": "shell",
                "command": "golangci-lint",
                "args": ["run"],
                "group": "test",
                "presentation": { "reveal": "always", "panel": "new" }
            },
            {
                "label": "Build",
                "detail": "go build",
                "type": "shell",
                "command": "go",
                "args": ["build", "-o", "${workspaceFolder}/bin/app", "."],
                "group": "build",
                "presentation": { "reveal": "always", "panel": "new" },
                "problemMatcher": ["$go"]
            }
        ]
    },
    "git.remote": "${GIT_REMOTE}"
}
