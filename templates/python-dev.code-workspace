{
    "folders": [
        { "path": "..", "name": "${PROJECT_NAME}" }
    ],
    "settings": {
        "editor.formatOnSave": true,
        "editor.tabSize": 4,
        "editor.rulers": [88, 120],
        "files.encoding": "utf8",
        "files.exclude": {
            "**/.git": true,
            "**/__pycache__": true,
            "**/*.pyc": true,
            "**/.pytest_cache": true,
            "**/.venv": true
        },
        "search.exclude": {
            "**/__pycache__": true,
            "**/.venv": true
        },
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
        "python.formatting.provider": "black",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true,
        "python.testing.pytestEnabled": true,
        "terminal.integrated.defaultProfile.windows": "PowerShell 7 (full)",
        "terminal.integrated.shellIntegration.enabled": true
    },
    "extensions": {
        "recommendations": [
            "ms-python.python",
            "ms-python.black-formatter",
            "ms-python.pylint",
            "charliermarsh.ruff",
            "ms-python.vscode-pylance",
            "njpwerner.autodocstring",
            "eamodio.gitlens",
            "editorconfig.editorconfig",
            "streetsidesoftware.code-spell-checker"
        ]
    },
    "tasks": {
        "version": "2.0.0",
        "tasks": [
            {
                "label": "Run Tests",
                "detail": "Run pytest with coverage",
                "type": "shell",
                "command": "python",
                "args": ["-m", "pytest", "--cov", "-v"],
                "group": "test",
                "presentation": { "reveal": "always", "panel": "new" },
                "problemMatcher": []
            },
            {
                "label": "Format Code",
                "detail": "Format with Black",
                "type": "shell",
                "command": "black",
                "args": ["."],
                "group": "none",
                "presentation": { "reveal": "always", "panel": "new" }
            },
            {
                "label": "Lint Code",
                "detail": "Run Ruff linter",
                "type": "shell",
                "command": "ruff",
                "args": ["check", "."],
                "group": "test",
                "presentation": { "reveal": "always", "panel": "new" },
                "problemMatcher": []
            }
        ]
    },
    "git.remote": "${GIT_REMOTE}"
}
