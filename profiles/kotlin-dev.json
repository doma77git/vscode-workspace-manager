{
    "name": "kotlin-dev",
    "version": "1.0",
    "description": "Kotlin development — Kotlin Language Server, Gradle",
    "tags": ["kotlin", "jvm", "android", "backend"],
    "theme": "Default Dark+",
    "icon": "symbol-event",
    "settings": "{\"editor.fontSize\":14,\"editor.tabSize\":4,\"editor.formatOnSave\":true,\"editor.rulers\":[120],\"kotlin.languageServer.enabled\":true,\"[kotlin]\":{\"editor.defaultFormatter\":\"fwcd.kotlin\"},\"terminal.integrated.defaultProfile.windows\":\"PowerShell 7 (full)\",\"terminal.integrated.shellIntegration.enabled\":true,\"workbench.colorTheme\":\"Default Dark+\"}",
    "extensions": "[{\"identifier\":{\"id\":\"fwcd.kotlin\"}},{\"identifier\":{\"id\":\"mathiasfrohlich.kotlin\"}}]",
    "keybindings": "[]",
    "globalState": "{}"
}
